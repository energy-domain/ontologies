@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@base <https://w3id.org/energy-domain/core#> .

<https://w3id.org/energy-domain/core> rdf:type owl:Ontology ;
                                      owl:versionIRI <https://w3id.org/energy-domain/core/0.0.1> .

#################################################################
#    Annotation Properties
#################################################################

dcterms:identifier rdf:type owl:AnnotationProperty ;
                   rdfs:label "identifier"@en ;
                   rdfs:comment "A unique identifier for the resource."@en .

skos:prefLabel rdf:type owl:AnnotationProperty ;
                rdfs:label "preferred label"@en ;
                rdfs:comment "The preferred lexical label for a resource in a given language."@en .

skos:altLabel rdf:type owl:AnnotationProperty ;
               rdfs:label "alternative label"@en ;
               rdfs:comment "An alternative lexical label for a resource."@en .

skos:definition rdf:type owl:AnnotationProperty ;
                 rdfs:label "definition"@en ;
                 rdfs:comment "A statement or formal explanation of the meaning of a concept."@en .

:ifc_equivalentClass rdf:type owl:AnnotationProperty ;
                     rdfs:label "IFC Equivalent Class"@en ;
                     rdfs:comment "The IFC class that is equivalent or analogous to this concept."@en .

:ifc_objectType rdf:type owl:AnnotationProperty ;
                rdfs:label "IFC Object Type"@en ;
                rdfs:comment "The Ifc 'ObjectType' property value for this concept."@en .

:ifc_predefinedType rdf:type owl:AnnotationProperty ;
                    rdfs:label "IFC Predefined Type"@en ;
                    rdfs:comment "The Ifc 'PredefinedType' enumeration value for this concept."@en .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/energy-domain/core#AnchoringCollar
:AnchoringCollar rdf:type owl:Class ;
                 rdfs:subClassOf :SplitCollar ;
                 dcterms:identifier "AnchoringCollar" ;
                 skos:prefLabel "Anchoring Collar"@en ;
                 skos:definition "A mechanical device used to stabilize and secure flexible pipes, risers, or umbilical systems to fixed structures in subsea applications. By clamping onto the outer layers of the pipe, it prevents unwanted movement during installation and operation, helping to maintain alignment and integrity under tension or compression."@en ;
                 skos:prefLabel "Colar de Ancoragem"@pt-br ;
                 :ifc_equivalentClass "IfcPipeFitting" ;
                 skos:altLabel "Anchor Clamp"@en ;
                 skos:altLabel "Anchoring Device"@en ;
                 skos:altLabel "Fixation Collar"@en ;
                 skos:altLabel "Securing Collar"@en .

###  https://w3id.org/energy-domain/core#AnchoringCollarType
:AnchoringCollarType rdf:type owl:Class ;
                     dcterms:identifier "AnchoringCollarType" ;
                     skos:prefLabel "Anchoring Collar Type"@en ;
                     skos:definition "A mechanical device used to stabilize and secure flexible pipes, risers, or umbilical systems to fixed structures in subsea applications. By clamping onto the outer layers of the pipe, it prevents unwanted movement during installation and operation, helping to maintain alignment and integrity under tension or compression."@en ;
                     skos:prefLabel "Tipo de Colar de Ancoragem"@pt-br ;
                     :ifc_equivalentClass "IfcPipeFittingType" ;
                     skos:altLabel "Anchor Clamp"@en ;
                     skos:altLabel "Anchoring Device"@en ;
                     skos:altLabel "Fixation Collar"@en ;
                     skos:altLabel "Securing Collar"@en ;
                     :ifc_predefinedType "USERDEFINED" .

###  https://w3id.org/energy-domain/core#AnodeCollarSet
:AnodeCollarSet rdf:type owl:Class ;
                rdfs:subClassOf :SplitCollar ;
                dcterms:identifier "AnodeCollarSet" ;
                skos:prefLabel "Anode Collar Set"@en ;
                skos:definition "Sacrificial anode collar set used for corrosion protection in subsea environments. It is designed to attach around pipes or risers and undergo controlled corrosion, thus protecting the metallic structures from rust and degradation. Typically made from zinc or aluminum, it ensures the longevity of subsea equipment by sacrificing itself to prevent corrosion on critical infrastructure."@en ;
                skos:prefLabel "Conjunto de Colares de Anodo"@pt-br ;
                :ifc_equivalentClass "IfcPipeFitting" ;
                skos:altLabel "Anode Clamp"@en ;
                skos:altLabel "Cathodic Protection Collar"@en ;
                skos:altLabel "Anode Bracket"@en .

###  https://w3id.org/energy-domain/core#AnodeCollarSetType
:AnodeCollarSetType rdf:type owl:Class ;
                    dcterms:identifier "AnodeCollarSetType" ;
                    skos:prefLabel "Anode Collar Set Type"@en ;
                    skos:definition "Sacrificial anode collar set used for corrosion protection in subsea environments. It is designed to attach around pipes or risers and undergo controlled corrosion, thus protecting the metallic structures from rust and degradation. Typically made from zinc or aluminum, it ensures the longevity of subsea equipment by sacrificing itself to prevent corrosion on critical infrastructure."@en ;
                    skos:prefLabel "Tipo de Conjunto de Colares de Anodo"@pt-br ;
                    :ifc_equivalentClass "IfcPipeFittingType" ;
                    skos:altLabel "Anode Clamp"@en ;
                    skos:altLabel "Cathodic Protection Collar"@en ;
                    skos:altLabel "Anode Bracket"@en ;
                    skos:altLabel "CP Collar"@en ;
                    :ifc_predefinedType "USERDEFINED" .

###  https://w3id.org/energy-domain/core#AntiCollapseSheath
:AntiCollapseSheath rdf:type owl:Class ;
                    rdfs:subClassOf :SolidLayer ;
                    dcterms:identifier "AntiCollapseSheath" ;
                    skos:prefLabel "Anti Collapse Sheath"@en ;
                    skos:definition "Reinforcement layer in subsea flexible pipes used in oil and gas exploration, designed to prevent the collapse of the pipe under high external pressure conditions, such as those encountered in deepwater environments. Its primary role is to provide structural support against external forces that could compress or deform the pipe, particularly during situations where the internal pressure is reduced or absent, like when the pipe is emptied. Typically made from high-strength metallic or polymeric materials, the Anti Collapse Sheath ensures the integrity of the flexible pipe under extreme conditions."@en ;
                    skos:prefLabel "Capa Anti-Colapso"@pt-br ;
                    :ifc_equivalentClass "IfcPipeSegment" .

###  https://w3id.org/energy-domain/core#AntiWearSheath
:AntiWearSheath rdf:type owl:Class ;
                rdfs:subClassOf :SolidLayer ;
                dcterms:identifier "AntiWearSheath" ;
                skos:prefLabel "Anti Wear Sheath"@en ;
                skos:definition "Reinforcement layer in subsea flexible pipes used in oil and gas exploration, designed to protect the pipe from external wear and abrasion caused by contact with the seabed, equipment, or other subsea elements. Its primary role is to provide a durable protective barrier that shields the underlying layers from mechanical damage, extending the lifespan of the flexible pipe. Typically made from wear-resistant polymeric materials, the Anti Wear Sheath ensures the pipe's integrity by reducing the risk of surface damage under harsh operating conditions."@en ;
                skos:prefLabel "Capa Anti-Atrito"@pt-br ;
                :ifc_equivalentClass "IfcPipeSegment" .

###  https://w3id.org/energy-domain/core#ArmourLayer
:ArmourLayer rdf:type owl:Class ;
             rdfs:subClassOf :WoundLayer ;
             dcterms:identifier "ArmourLayer" ;
             skos:prefLabel "Armour Layer"@en ;
             skos:definition "A reinforcement layer in subsea flexible pipes used in oil and gas exploration, designed to provide mechanical strength and protection against external forces, such as pressure and movement. It ensures structural integrity by preventing deformation and failure during operation. Typically made from high-strength metal wires, like carbon steel or stainless steel, the Armor Layer enhances the pipe's durability in harsh underwater conditions."@en ;
             skos:prefLabel "Camada de Armadura"@pt-br .

###  https://w3id.org/energy-domain/core#Asset
:Asset rdf:type owl:Class ;
       rdfs:subClassOf :DomainObject ;
       dcterms:identifier "Asset" ;
       skos:prefLabel "Asset"@en ;
       skos:definition "An asset refers to valuable resources such as platforms, equipment, pipelines, and processing facilities crucial for production and transportation. These assets are managed to optimize performance, ensure safety, and maximize operational efficiency throughout their lifecycle."@en ;
       skos:prefLabel "Ativo"@pt-br .

###  https://w3id.org/energy-domain/core#AssetType
:AssetType rdf:type owl:Class ;
           dcterms:identifier "AssetType" ;
           skos:prefLabel "Asset Type"@en ;
           skos:definition "An asset refers to valuable resources such as platforms, equipment, pipelines, and processing facilities crucial for production and transportation. These assets are managed to optimize performance, ensure safety, and maximize operational efficiency throughout their lifecycle."@en ;
           skos:prefLabel "Tipo de Ativo"@pt-br .

###  https://w3id.org/energy-domain/core#BendRestrictor
:BendRestrictor rdf:type owl:Class ;
                rdfs:subClassOf :LineAncillary ;
                dcterms:identifier "BendRestrictor" ;
                skos:prefLabel "Bend Restrictor"@en ;
                skos:definition "Device used in subsea flexible pipes to limit the bending radius and prevent over-bending that could damage the pipe. Typically installed near critical areas such as connectors or end fittings, where excessive bending could compromise the structural integrity of the pipe. The Bend Restrictor consists of multiple interlocking segments that allow flexibility up to a certain radius, beyond which the segments lock to prevent further bending, protecting the pipe from deformation or failure in harsh subsea environments."@en ;
                skos:prefLabel "Restritor de Curvatura"@pt-br ;
                :ifc_equivalentClass "IfcPipeFitting" ;
                skos:altLabel "Bend Limiter"@en ;
                skos:altLabel "Bending Restrictor"@en ;
                skos:altLabel "Curvature Limiter"@en .

###  https://w3id.org/energy-domain/core#BendRestrictorType
:BendRestrictorType rdf:type owl:Class ;
                    dcterms:identifier "BendRestrictorType" ;
                    skos:prefLabel "Bend Restrictor Type"@en ;
                    skos:definition "Device used in subsea flexible pipes to limit the bending radius and prevent over-bending that could damage the pipe. Typically installed near critical areas such as connectors or end fittings, where excessive bending could compromise the structural integrity of the pipe. The Bend Restrictor consists of multiple interlocking segments that allow flexibility up to a certain radius, beyond which the segments lock to prevent further bending, protecting the pipe from deformation or failure in harsh subsea environments."@en ;
                    skos:prefLabel "Tipo de Restritor de Curvatura"@pt-br ;
                    :ifc_equivalentClass "IfcPipeFittingType" ;
                    skos:altLabel "Bend Limiter"@en ;
                    skos:altLabel "Bending Restrictor"@en ;
                    skos:altLabel "Curvature Limiter"@en ;
                    skos:altLabel "Flex Restrictor"@en ;
                    :ifc_predefinedType "USERDEFINED" .

###  https://w3id.org/energy-domain/core#BendStiffener
:BendStiffener rdf:type owl:Class ;
               rdfs:subClassOf :LineAncillary ;
               dcterms:identifier "BendStiffener" ;
               skos:prefLabel "Bend Stiffener"@en ;
               skos:definition "Device used in subsea flexible pipes to provide gradual stiffness transition between the flexible pipe and a fixed structure, preventing excessive bending at critical areas such as terminations or connectors. The Bend Stiffener is designed to manage stress concentration by stiffening the pipe over a defined length, reducing the risk of damage due20to repeated bending, fatigue, or over-flexing. Typically made from high-strength materials, it ensures the long-term structural integrity of the pipe in dynamic subsea environments."@en ;
               skos:prefLabel "Enrijecedor de Curvatura"@pt-br .

###  https://w3id.org/energy-domain/core#BendStiffenerType
:BendStiffenerType rdf:type owl:Class ;
                   dcterms:identifier "BendStiffenerType" ;
                   skos:prefLabel "Bend Stiffener Type"@en ;
                   skos:definition "Device used in subsea flexible pipes to provide gradual stiffness transition between the flexible pipe and a fixed structure, preventing excessive bending at critical areas such as terminations or connectors. The Bend Stiffener is designed to manage stress concentration by stiffening the pipe over a defined length, reducing the risk of damage due to repeated bending, fatigue, or over-flexing. Typically made from high-strength materials, it ensures the long-term structural integrity of the pipe in dynamic subsea environments."@en ;
                   skos:prefLabel "Tipo de Enrijecedor de Curvatura"@pt-br ;
                   :ifc_equivalentClass "IfcPipeFittingType" ;
                   :ifc_predefinedType "USERDEFINED" .

###  https://w3id.org/energy-domain/core#BoltSet
:BoltSet rdf:type owl:Class ;
         rdfs:subClassOf :PhysicalConnection ;
         dcterms:identifier "BoltSet" ;
         skos:prefLabel "Bolt Set"@en ;
         skos:definition "A collection of bolts and nuts, and washers designed for fastening components in subsea systems. Bolt sets are critical for ensuring structural integrity and are selected based on size, material, and application requirements."@en ;
         skos:prefLabel "Conjunto de Parafusos"@pt-br .

###  https://w3id.org/energy-domain/core#BuoyancyModule
:BuoyancyModule rdf:type owl:Class ;
                rdfs:subClassOf :LineAncillary ;
                dcterms:identifier "BuoyancyModule" ;
                skos:prefLabel "Buoyancy Module"@en ;
                skos:definition "Device used in subsea systems to provide controlled buoyancy to flexible pipes, risers, or umbilicals, reducing the load on the structure and managing the configuration of the line in the water column. The Buoyancy Module is typically composed of syntactic foam or other materials with low density, designed to withstand high external pressures while maintaining its buoyant properties over time. It plays a key role in optimizing the performance and positioning of subsea lines, ensuring they maintain the required shape and depth in dynamic ocean conditions."@en ;
                skos:prefLabel "Módulo de Flutuação"@pt-br ;
                :ifc_equivalentClass "IfcPipeFitting" ;
                skos:altLabel "Buoyancy Element"@en ;
                skos:altLabel "Floatation Module"@en ;
                skos:altLabel "Buoyancy Unit"@en ;
                skos:altLabel "Subsea Buoyancy Module"@en .

###  https://w3id.org/energy-domain/core#BuoyancyModuleType
:BuoyancyModuleType rdf:type owl:Class ;
                    dcterms:identifier "BuoyancyModuleType" ;
                    skos:prefLabel "Buoyancy Module Type"@en ;
                    skos:definition "Device used in subsea systems to provide controlled buoyancy to flexible pipes, risers, or umbilicals, reducing the load on the structure and managing the configuration of the line in the water column. The Buoyancy Module is typically composed of syntactic foam or other materials with low density, designed to withstand high external pressures while maintaining its buoyant properties over time. It plays a key role in optimizing the performance and positioning of subsea lines, ensuring they maintain the required shape and depth in dynamic ocean conditions."@en ;
                    skos:prefLabel "Tipo de Módulo de Flutuação"@pt-br ;
                    :ifc_equivalentClass "IfcPipeFittingType" ;
                    skos:altLabel "Buoyancy Element"@en ;
                    skos:altLabel "Floatation Module"@en ;
                    skos:altLabel "Buoyancy Unit"@en ;
                    skos:altLabel "Subsea Buoyancy Device"@en ;
                    :ifc_predefinedType "USERDEFINED" .

###  https://w3id.org/energy-domain/core#CarcassLayer
:CarcassLayer rdf:type owl:Class ;
              rdfs:subClassOf :ArmourLayer ;
              dcterms:identifier "CarcassLayer" ;
              skos:prefLabel "Carcass Layer"@en ;
              skos:definition " A reinforcement layer in subsea flexible pipes that provides structural strength and stability. It helps maintain the shape and integrity of the pipe under operational pressure, ensuring the flexibility of the pipe while protecting the internal components. Typically made from metal or polymer materials, it acts as a foundation for the other protective layers."@en ;
              skos:prefLabel "Camada de Carcaça"@pt-br .

###  https://w3id.org/energy-domain/core#CompactObject
:CompactObject rdf:type owl:Class ;
               rdfs:subClassOf :Asset ;
               rdfs:label "Compact Object"@en ;
               dcterms:identifier "CompactObject" ;
               skos:prefLabel "Compact Object"@en ;
               skos:definition "A mobile physical object, usually manufactured in a standardized manner."@en ;
               skos:prefLabel "Objeto Compacto"@pt-br .

